<?xml version="1.0" encoding="UTF-8"?>
<!--
  This is a single-page site, so the sitemap has just one <url> entry —
  that's correct and expected, not a mistake. Search engines don't need
  separate entries for #about, #services, etc.; those are anchors within
  the same page, not separate crawlable documents.

  If you later move from the free dakeiro.netlify.app address to a real
  purchased domain, update the URL below (and in Dakeiro.html's <head>
  and robots.txt) to match — a sitemap pointing at the wrong domain is
  worse than no sitemap at all.
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>https://dakeiro.netlify.app/</loc>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>
</urlset>
